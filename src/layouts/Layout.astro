---
// FINÁLNA VERZIA: src/layouts/Layout.astro
import { ViewTransitions } from 'astro:transitions';
import '../styles/styles.css';


interface Props {
	title: string;
	description: string;
	image?: string; 
    pageType?: string;
}

const { title, description, image, pageType = 'home' } = Astro.props;

// --- NOVÁ ČASŤ: Logika pre dynamický obrázok ---
// Vytvoríme finálnu URL. Ak je 'image' definovaný (poslaný zo stránky), použije sa.
// Ak nie, použije sa predvolený obrázok 'obrazokobchodu.webp'.
const finalImageURL = new URL(image || '/img/obrazokobchodu.webp', Astro.site).href;
// --- KONIEC NOVEJ ČASTI ---
---
<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <ViewTransitions />
    
    <title>{title}</title>
    <meta name="description" content={description}>

    <meta name="keywords" content="kvetinárstvo Trenčianska Teplá, kvety Trenčianska Teplá, donáška kvetov Trenčianska Teplá, svadobné kytice Trenčianska Teplá, pohrebné vence Trenčianska Teplá, rezané kvety, kytice na mieru, kvetinárstvo v okolí, online kvetinárstvo, Kytica od srdca">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#ffffff">
   

    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href}>
    
    {/* ZMENA: Použili sme novú premennú 'finalImageURL' */}
    <meta property="og:image" content={finalImageURL}>
    
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="sk_SK">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    
    {/* ZMENA: Použili sme novú premennú 'finalImageURL' */}
    <meta name="twitter:image" content={finalImageURL}>

    {/* Slot pre ďalšie SEO tagy z podstránok */}
    <slot name="head" />

    <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "Florist",
  "name": "Kytica od srdca",
  "url": "https://kyticaodsrdca.sk",
  "logo": "https://kyticaodsrdca.sk/img/obrazokobchodu.webp",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Trenčianska Teplá",
    "addressCountry": "SK"
  }
}
</script>
</head>
<body data-page={pageType}>
    <div id="custom-cursor"></div>
    <slot />
    <script src="../scripts/script.js"></script>
</body>
</html>