---
// Súbor: src/components/BlogPostCard.astro
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, image, tags } = post.data;

const getTagClass = (tag: string) => {
switch (tag.toLowerCase()) {
case 'svadba':
case 'trendy':
return 'tag-wedding';
case 'starostlivosť':
case 'tipy':
return 'tag-care';
case 'inšpirácia':
return 'tag-inspiration';
case 'sezónne':
return 'tag-seasonal';
default:
return '';
}
};
---
<article class="blog-post-card fade-in-element">
<a href={`/blog/${post.slug}/`} class="post-card-image-link">
<Image src={image.url} alt={image.alt} class="post-card-image" loading="lazy" />
</a>

<div class="post-card-content">
<div class="card-header">
<div class="post-card-tags">
{tags.map(tag => (
<span class={`tag ${getTagClass(tag)}`}>{tag}</span>
))}
</div>
<h3 class="post-card-title">
<a href={`/blog/${post.slug}/`}>{title}</a>
</h3>
</div>

<p class="post-card-description">{description}</p>
</div>
</article>

<style>
.blog-post-card {
display: flex;
flex-direction: column;
background-color: var(--secondary-bg-color);
border: 1px solid var(--border-color);
border-radius: var(--border-radius-md);
overflow: hidden;
}

.post-card-image-link {
display: block;
line-height: 0;
aspect-ratio: 16 / 10;
overflow: hidden;
}
.post-card-image {
width: 100%;
height: 100%;
object-fit: cover;
}

.post-card-content {
display: flex;
flex-direction: column;
flex-grow: 1; /* Povie textovému bloku, aby vyplnil všetko voľné miesto */
padding: 2.5rem;
}

.card-header {
/* Tento blok bude mať vždy rovnakú minimálnu výšku */
min-height: 9rem;
}

.post-card-tags {
display: flex;
flex-wrap: wrap;
gap: 0.8rem;
margin-bottom: 1.5rem;
}

.post-card-title {
font-family: var(--font-heading);
font-size: 2.25rem;
font-weight: 600;
line-height: 1.4;
}
.post-card-title a {
color: var(--text-color);
text-decoration: none;
transition: color 0.3s ease;
}
.post-card-title a:hover {
color: var(--accent-color);
}

.post-card-description {
font-size: 1.6rem;
color: var(--text-color);
line-height: 1.65;
opacity: 0.8;
margin-top: auto; /* Kľúčová vlastnosť: odtlačí popis na spodok voľného miesta */
padding-top: 1rem;
}
</style>

