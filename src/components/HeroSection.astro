---
// Súbor: src/components/HeroSection.astro
import heroPosterDesktop from '../assets/img/obchodtit.webp';
import heroPosterMobile from '../assets/img/obrazokobchodu.webp';
---
<section class="hero" id="home">
    <!-- Desktop Video -->
    <video class="hero-video hero-desktop" autoplay loop muted playsinline disablePictureInPicture poster={heroPosterDesktop.src}>
        <source src="https://kytica.b-cdn.net/Kyticadesktop.mp4" type="video/mp4" />
    </video>
    
    <!-- Mobile Video -->
    <video class="hero-video hero-mobile" autoplay loop muted playsinline disablePictureInPicture poster={heroPosterMobile.src}>
        <source src="https://kytica.b-cdn.net/Kyticamob.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>

    <div class="hero-content">
        <span class="hero-eyebrow">Kvetinárstvo Kytica od srdca v Trenčianskej Teplej</span>
        <h1>Prekvapte krásou,<br><em>dotknite sa srdca</em></h1>
        <p class="hero-sub">Čerstvé. Sezónne. S dušou.</p>
        <div class="hero-actions">
            <a href="https://online.kyticaodsrdca.sk" target="_blank" rel="noopener noreferrer" class="btn btn-primary" id="fcHeroBtn">ONLINE ponuka</a>
            <a href="tel:+421940181839" class="btn btn-secondary">Zavolať</a>
        </div>
    </div>

    <div class="hero-scroll">
        <div class="scroll-line"></div>
        <span>Scroll</span>
    </div>
</section>